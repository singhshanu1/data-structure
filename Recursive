#include<stdio.h>

int fib_recur(int n) {
    if (n == 1 || n == 2) {
        return(n-1);
    } else {
        return(fib_recur(n-1) + fib_recur(n-2));
    }
}

void input_num(int *n) {
    printf("Enter a number : ");
    scanf("%d",n);
}

int main() {
    int a;
    input_num(&a);
    printf("The Fibonacci Series is : %d",fib_recur(a));
    return 0;
}
